<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="12" xmlns:fx="http://javafx.com/fxml" fx:controller="com.heladeria.controllers.NotaVentaFormController">
    <padding>
        <Insets bottom="15" left="15" right="15" top="15"/>
    </padding>

    <Text text="Formulario de Nota de Venta" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <VBox spacing="8" style="-fx-border-color: #ccc; -fx-border-radius: 5; -fx-padding: 10;">
        <Text text="Datos del Cliente" style="-fx-font-weight: bold;"/>
        <CheckBox fx:id="nuevoClienteCheck" text="Cliente nuevo"/>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Cliente existente:"/>
            <ComboBox fx:id="clienteCombo" prefWidth="300"/>
        </HBox>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Nombre nuevo cliente:"/>
            <TextField fx:id="clienteNombreField" prefWidth="300" disable="true"/>
        </HBox>
    </VBox>

    <VBox spacing="8" style="-fx-border-color: #ccc; -fx-border-radius: 5; -fx-padding: 10;">
        <Text text="Agregar Detalle" style="-fx-font-weight: bold;"/>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Sabor:"/>
            <ComboBox fx:id="saborCombo" prefWidth="200"/>
            <Label text="Cantidad:"/>
            <TextField fx:id="cantidadField" prefWidth="80"/>
            <Button fx:id="addDetalleBtn" text="Agregar"/>
        </HBox>
    </VBox>

    <Text text="Detalle de la Nota de Venta" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

    <TableView fx:id="detalleTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colSabor" text="Sabor" prefWidth="200"/>
            <TableColumn fx:id="colCantidad" text="Cantidad" prefWidth="100"/>
            <TableColumn fx:id="colSubtotal" text="Subtotal" prefWidth="150"/>
        </columns>
    </TableView>

    <HBox spacing="10">
        <Button fx:id="removeDetalleBtn" text="Eliminar Detalle Seleccionado"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Text text="Total: $" style="-fx-font-size: 16px;"/>
        <Label fx:id="totalLabel" text="0.00" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="saveButton" text="Guardar Nota de Venta" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px;"/>
        <Button fx:id="cancelButton" text="Cancelar" style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-font-size: 14px;"/>
    </HBox>
</VBox>
