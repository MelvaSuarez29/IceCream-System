<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox spacing="10" style="-fx-background-image: url(&quot;file:/C:/Users/USUARIO/Downloads/Proyectos/heladeria_test/src/main/resources/com/heladeria/img/img-6.jpg&quot;); -fx-background-position: center; -fx-background-size: cover;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/26" fx:controller="com.heladeria.controllers.VendedorController">
    <padding>
        <Insets bottom="15" left="15" right="15" top="15" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Text style="-fx-font-size: 22px; -fx-font-weight: bold;" text="Panel de Vendedor" HBox.hgrow="ALWAYS" />
        <Button fx:id="logoutButton" style="-fx-background-color: #f44336; -fx-text-fill: white;" text="Cerrar Sesión" />
    </HBox>

    <SplitPane dividerPositions="0.5" VBox.vgrow="ALWAYS">
        <VBox spacing="10">
            <Text style="-fx-font-size: 14px; -fx-font-weight: bold;" text="Sabores Disponibles" />
            <TableView fx:id="saboresTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colSaborNombre" prefWidth="120" text="Nombre" />
                    <TableColumn fx:id="colSaborPrecio" prefWidth="80" text="Precio" />
                    <TableColumn fx:id="colSaborStock" prefWidth="80" text="Stock" />
                </columns>
            </TableView>
        </VBox>

        <VBox spacing="10">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Text style="-fx-font-size: 14px; -fx-font-weight: bold;" text="Mis Notas de Venta" HBox.hgrow="ALWAYS" />
                <Button fx:id="createFacturaBtn" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="Crear Nota de Venta" />
            </HBox>

            <TableView fx:id="facturasTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colFactFecha" prefWidth="140" text="Fecha" />
                    <TableColumn fx:id="colFactCliente" prefWidth="120" text="Cliente" />
                    <TableColumn fx:id="colFactTotal" prefWidth="100" text="Total" />
                </columns>
            </TableView>

            <Label fx:id="clienteInfoLabel" style="-fx-font-style: italic;" text="" />

            <TableView fx:id="detalleTable" prefHeight="150">
                <columns>
                    <TableColumn fx:id="colDetSabor" prefWidth="100" text="Sabor" />
                    <TableColumn fx:id="colDetCantidad" prefWidth="60" text="Cant." />
                    <TableColumn fx:id="colDetSubtotal" prefWidth="100" text="Subtotal" />
                </columns>
            </TableView>

            <HBox spacing="10">
                <Button fx:id="editFacturaBtn" style="-fx-background-color: #FF9A20; -fx-text-fill: white;" text="Editar Nota de Venta" />
                <Button fx:id="deleteFacturaBtn" style="-fx-background-color: #f44336; -fx-text-fill: white;" text="Anular Nota de Venta" />
            </HBox>
        </VBox>
    </SplitPane>
</VBox>
